# Copy this file to .env.local and fill in real values. Never commit .env.local.

# --- Phase 1: Foundation ---

# Supabase project settings (Project Settings > API)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Supabase project settings (Project Settings > Database > Connection string,
# use the "Transaction" pooled connection for serverless — see Phase 8 note)
DATABASE_URL=

# Auth.js / NextAuth — the URL of this deployment (http://localhost:3000 in dev)
NEXTAUTH_URL=
# Generate with: npx auth secret
NEXTAUTH_SECRET=

# Google Cloud Console > APIs & Services > Credentials > OAuth client ID
# (Web application type; add NEXTAUTH_URL + /api/auth/callback/google as an
# authorized redirect URI)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Any long random string you generate yourself. Shared between this app's
# Vercel env vars and the GitHub Actions repo secret of the same name —
# see .github/workflows/pipeline.yml (added in Phase 7).
CRON_SECRET=

# --- Phase 2: Job Ingestion ---
# Job source API keys added here as sources are picked (e.g. ADZUNA_APP_ID,
# ADZUNA_APP_KEY, JSEARCH_RAPIDAPI_KEY). None required for manual job entry.

# --- Phase 3: Profile Ingestion ---
# (Uses SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY above for Storage — no new vars)

# --- Phase 4/5: Matching & Drafting ---
# Google AI Studio (aistudio.google.com) > Get API key
GEMINI_API_KEY=

# --- Phase 7: Notifications & Scheduling ---
# Same Google OAuth client as above; Gmail `send` scope is requested
# incrementally when the user enables notifications, no new client needed.
